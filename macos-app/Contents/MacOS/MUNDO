#!/bin/bash
# MUNDO Agent v2.1.0 — macOS .app 启动脚本
# 启动前自动从 GitHub 同步最新版本

osascript <<'APPLESCRIPT'
tell application "Terminal"
    activate
    do script "
        clear
        echo \"\"
        echo \"  👑 MUNDO — THE EMPEROR v2.1.0\"
        echo \"  ════════════════════════════\"
        echo \"\"
        
        cd ~/.hermes/mundo-agent
        
        # ═══ 自动从 GitHub 同步最新版本 ═══
        if [ -d .git ]; then
            LOCAL_VER=$(cat version.txt 2>/dev/null | tr -d '[:space:]')
            echo \"  📦 本地版本: v\$LOCAL_VER\"
            echo \"  🔄 检查 GitHub 更新...\"
            
            git fetch origin main --quiet 2>/dev/null
            LOCAL_HASH=\$(git rev-parse HEAD 2>/dev/null)
            REMOTE_HASH=\$(git rev-parse origin/main 2>/dev/null)
            
            if [ \"\$LOCAL_HASH\" != \"\$REMOTE_HASH\" ]; then
                echo \"  ⬇️  发现新版本，自动更新中...\"
                git pull origin main --quiet 2>/dev/null
                NEW_VER=$(cat version.txt 2>/dev/null | tr -d '[:space:]')
                echo \"  ✅ 已更新: v\$LOCAL_VER → v\$NEW_VER\"
            else
                echo \"  ✅ 已是最新版本\"
            fi
        else
            echo \"  ⚠️  未检测到 Git 仓库，跳过同步\"
        fi
        
        echo \"\"
        echo \"  🚀 启动蒙多...\"
        echo \"\"
        
        # ═══ 启动蒙多 ═══
        source venv/bin/activate 2>/dev/null
        python3 mundo.py
    "
    set custom title of front window to "MUNDO — THE EMPEROR"
end tell
APPLESCRIPT
