#!/bin/bash
# MUNDO Agent v2.3.1 — macOS 程序坞启动器
# 每次启动强制同步最新版，验证版本后运行

export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$PATH"
export LANG=zh_CN.UTF-8
export LC_ALL=zh_CN.UTF-8

# 程序坞/Finder 启动时 HOME 可能未设置
if [ -z "${HOME:-}" ]; then
    USER_NAME="$(/usr/bin/id -un 2>/dev/null || echo "")"
    if [ -n "$USER_NAME" ] && [ -d "/Users/$USER_NAME" ]; then
        export HOME="/Users/$USER_NAME"
    else
        export HOME="$(/usr/bin/eval echo "~$USER_NAME")"
    fi
fi

show_error() {
    osascript -e "display dialog \"$1\" buttons {\"确定\"} default button \"确定\" with icon stop with title \"MUNDO Error\""
    exit 1
}

# 定位同步脚本
SYNC_SCRIPT=""
for candidate in \
    "$(dirname "$0")/../Resources/mundo-sync.sh" \
    "$HOME/.hermes/mundo-agent/mundo-sync.sh" \
    "$HOME/Desktop/MUNDO/mundo-agent/mundo-sync.sh" \
    "$HOME/Desktop/lihongwei-cn/mundo-agent/mundo-sync.sh"; do
    if [ -f "$candidate" ]; then
        SYNC_SCRIPT="$candidate"
        break
    fi
done

MUNDO_HOME="$HOME/.hermes/mundo-agent"
mkdir -p "$HOME/.hermes"

# 尝试同步；失败时若已有安装则降级启动
SYNC_OK=0
if [ -n "$SYNC_SCRIPT" ]; then
    if bash "$SYNC_SCRIPT"; then
        SYNC_OK=1
    fi
fi

if [ "$SYNC_OK" -eq 0 ] && [ ! -f "$MUNDO_HOME/mundo.py" ]; then
    show_error "蒙多同步失败！\\n\\n请确认以下目录之一存在：\\n~/Desktop/MUNDO/mundo-agent\\n~/.hermes/mundo-agent"
fi

VENV_PYTHON="$MUNDO_HOME/venv/bin/python3"

# 写入 Terminal 启动脚本（避免 osascript 引号嵌套问题）
cat > "$HOME/.hermes/MUNDO.command" << COMMAND
#!/bin/bash
cd "$MUNDO_HOME"
export PYTHONDONTWRITEBYTECODE=1
if [ -x "$VENV_PYTHON" ]; then
  exec "$VENV_PYTHON" mundo.py "\$@"
else
  exec python3 mundo.py "\$@"
fi
COMMAND
chmod +x "$HOME/.hermes/MUNDO.command"

INSTALLED_VER=$(cat "$MUNDO_HOME/version.txt" 2>/dev/null | tr -d '[:space:]' || echo "unknown")

/usr/bin/osascript -e "tell application \"Terminal\" to activate" \
  -e "tell application \"Terminal\" to do script \"bash $HOME/.hermes/MUNDO.command\"" \
  -e "tell application \"Terminal\" to set custom title of front window to \"MUNDO v$INSTALLED_VER\""
