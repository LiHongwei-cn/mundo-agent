#!/bin/bash
# MUNDO — THE EMPEROR 终端启动脚本
# 由MUNDO.app调用，在Terminal.app中运行

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MUNDO_DIR=""

# 定位目录（从Contents/MacOS向上3级到MUNDO.app所在目录）
[ -f "$SCRIPT_DIR/../../../mundo.py" ] && MUNDO_DIR="$(cd "$SCRIPT_DIR/../../../" && pwd)"
[ -z "$MUNDO_DIR" ] && [ -f "$HOME/蒙多/mundo.py" ] && MUNDO_DIR="$HOME/蒙多"
[ -z "$MUNDO_DIR" ] && [ -f "$HOME/Desktop/lihongwei-cn/mundo-agent/mundo.py" ] && MUNDO_DIR="$HOME/Desktop/lihongwei-cn/mundo-agent"
[ -z "$MUNDO_DIR" ] && [ -f "$HOME/.hermes/mundo-agent/mundo.py" ] && MUNDO_DIR="$HOME/.hermes/mundo-agent"

if [ -z "$MUNDO_DIR" ]; then
    echo "❌ 找不到蒙多主程序"
    read -p "按回车退出..."
    exit 1
fi

# Python
PYTHON=""
[ -f "$MUNDO_DIR/venv/bin/python3" ] && PYTHON="$MUNDO_DIR/venv/bin/python3"
[ -z "$PYTHON" ] && PYTHON="python3"

cd "$MUNDO_DIR"

# ═══ 清理 Python 字节码缓存 ═══
rm -rf __pycache__

export PYTHONPATH="$MUNDO_DIR:$PYTHONPATH"
export MUNDO_HOME="$MUNDO_DIR"
export MUNDO_LAUNCHED_FROM="app"
export PYTHONIOENCODING="utf-8"
export LANG="zh_CN.UTF-8"
export PYTHONDONTWRITEBYTECODE=1

# 检查依赖
for pkg in requests rich prompt_toolkit; do
    $PYTHON -c "import $pkg" 2>/dev/null || $PYTHON -m pip install "$pkg" --quiet 2>/dev/null
done

# 显示版本
VER=$($PYTHON -c "import sys; sys.path.insert(0,'.'); from constants import VERSION; print(VERSION)" 2>/dev/null || cat version.txt 2>/dev/null || echo 'unknown')
echo ""
echo "  MUNDO — THE EMPEROR $VER"
echo "  ════════════════════════"
echo ""

# 设置终端标题
echo -ne "\033]0;MUNDO — THE EMPEROR\007"

# 启动
exec $PYTHON mundo.py
